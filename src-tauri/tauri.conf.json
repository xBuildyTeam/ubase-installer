{
  "productName": "uBase Installer",
  "version": "1.0.0",
  "identifier": "tech.ubase.installer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "uBase Installer",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/xBuildyTeam/ubase-installer/releases/latest/download/latest.json"
      ],
      "pubkey": "jaSv+eF7xj/+Y+pTtc5XwKlxiW9lIXRvA69ehZX9CdA="
    },
    "shell": {
      "open": true
    },
    "fs": {
      "scope": [
        "$APPDIR/*",
        "$DOCUMENT/*",
        "$DOWNLOAD/*"
      ]
    },
    "deep-link": {
      "schemes": [
        "ubase"
      ]
    }
  }
}
